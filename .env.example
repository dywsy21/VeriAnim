# VeriAnim local harness configuration.
# Copy to .env and fill only the providers you use.

# Generic provider keys used by LiteLLM.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
OPENROUTER_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Optional OpenAI-compatible custom endpoint.
LITELLM_API_BASE=
LITELLM_API_KEY=

# Agent-specific model routing. LiteLLM model names are accepted, for example:
#   openai/gpt-4.1
#   gemini/gemini-2.5-pro
#   openrouter/qwen/qwen2.5-vl-72b-instruct
#   dashscope/qwen-vl-max
VERIANIM_PLANNER_MODEL=openai/gpt-4.1
VERIANIM_PLANNER_API_BASE=
VERIANIM_PLANNER_API_KEY=
VERIANIM_PLANNER_API_VERSION=
VERIANIM_PLANNER_PROVIDER=
VERIANIM_CODER_MODEL=openai/gpt-4.1
VERIANIM_CODER_API_BASE=
VERIANIM_CODER_API_KEY=
VERIANIM_CODER_API_VERSION=
VERIANIM_CODER_PROVIDER=
VERIANIM_REFINER_MODEL=openai/gpt-4.1
VERIANIM_REFINER_API_BASE=
VERIANIM_REFINER_API_KEY=
VERIANIM_REFINER_API_VERSION=
VERIANIM_REFINER_PROVIDER=
VERIANIM_VISION_MODEL=openai/gpt-4.1
VERIANIM_VISION_API_BASE=
VERIANIM_VISION_API_KEY=
VERIANIM_VISION_API_VERSION=
VERIANIM_VISION_PROVIDER=
VERIANIM_VIDEO_MODEL=dashscope/qwen-omni-turbo
VERIANIM_VIDEO_API_BASE=
VERIANIM_VIDEO_API_KEY=
VERIANIM_VIDEO_API_VERSION=
VERIANIM_VIDEO_PROVIDER=

# Per-agent sampling. Keep coder/refiner low temperature for code stability.
VERIANIM_PLANNER_TEMPERATURE=0.2
# Leave MAX_TOKENS empty to avoid sending an output cap to the provider.
# Set only when a gateway/model requires an explicit limit.
VERIANIM_PLANNER_MAX_TOKENS=
VERIANIM_PLANNER_TIMEOUT_SECONDS=
VERIANIM_CODER_TEMPERATURE=0.1
VERIANIM_CODER_MAX_TOKENS=
VERIANIM_CODER_TIMEOUT_SECONDS=
VERIANIM_CODER_STREAM=true
VERIANIM_REFINER_TEMPERATURE=0.1
VERIANIM_REFINER_MAX_TOKENS=
VERIANIM_REFINER_TIMEOUT_SECONDS=
VERIANIM_REFINER_STREAM=true
VERIANIM_REFINER_SUPPORTS_IMAGES=false
VERIANIM_VISION_TEMPERATURE=0.0
VERIANIM_VISION_MAX_TOKENS=
VERIANIM_VISION_TIMEOUT_SECONDS=
VERIANIM_VISION_SUPPORTS_IMAGES=true
VERIANIM_VIDEO_TEMPERATURE=0.0
VERIANIM_VIDEO_MAX_TOKENS=
VERIANIM_VIDEO_TIMEOUT_SECONDS=
VERIANIM_VIDEO_SUPPORTS_IMAGES=true

# Harness controls.
VERIANIM_DOTENV_OVERRIDE=true
VERIANIM_LLM_STREAM=true
VERIANIM_LLM_TIMEOUT_SECONDS=90
VERIANIM_MAX_REFINEMENT_ROUNDS=2
VERIANIM_MAX_VISUAL_REFINEMENT_ROUNDS=6
VERIANIM_MAX_VIDEO_REFINEMENT_ROUNDS=6
VERIANIM_MAX_STAGNANT_REFINEMENT_ROUNDS=3
VERIANIM_PLANNER_MAX_RETRIES=1
VERIANIM_RAG_DOCS=docs/rag,docs/ir.md
VERIANIM_RUNS_DIR=runs
VERIANIM_BLENDER_HOST=localhost
VERIANIM_BLENDER_PORT=8888
VERIANIM_HEADLESS_RENDERING=false
VERIANIM_RENDER_WIDTH=1280
VERIANIM_RENDER_HEIGHT=720
VERIANIM_RENDER_GIF_EACH_ROUND=true
VERIANIM_TEXTURE_SEARCH_ENABLED=true
VERIANIM_TEXTURE_SEARCH_CANDIDATE_LIMIT=4
VERIANIM_TEXTURE_SEARCH_TIMEOUT_SECONDS=20
VERIANIM_TUI_INITIAL_ANIMATION=false
VERIANIM_TUI_SKIP_VISION=false
VERIANIM_TUI_SKIP_VIDEO=false
