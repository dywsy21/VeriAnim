# LL3M local harness configuration.
# Copy to .env and fill only the providers you use.

# Generic provider keys used by LiteLLM.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
OPENROUTER_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Optional OpenAI-compatible custom endpoint.
LITELLM_API_BASE=
LITELLM_API_KEY=

# Agent-specific model routing. LiteLLM model names are accepted, for example:
#   openai/gpt-4.1
#   anthropic/claude-3-7-sonnet-latest
#   gemini/gemini-2.5-pro
#   openrouter/qwen/qwen2.5-vl-72b-instruct
#   dashscope/qwen-vl-max
LL3M_PLANNER_MODEL=openai/gpt-4.1
LL3M_PLANNER_API_BASE=
LL3M_PLANNER_API_KEY=
LL3M_PLANNER_API_VERSION=
LL3M_PLANNER_PROVIDER=
LL3M_CODER_MODEL=openai/gpt-4.1
LL3M_CODER_API_BASE=
LL3M_CODER_API_KEY=
LL3M_CODER_API_VERSION=
LL3M_CODER_PROVIDER=
LL3M_REFINER_MODEL=openai/gpt-4.1
LL3M_REFINER_API_BASE=
LL3M_REFINER_API_KEY=
LL3M_REFINER_API_VERSION=
LL3M_REFINER_PROVIDER=
LL3M_VISION_MODEL=openai/gpt-4.1
LL3M_VISION_API_BASE=
LL3M_VISION_API_KEY=
LL3M_VISION_API_VERSION=
LL3M_VISION_PROVIDER=
LL3M_VIDEO_MODEL=dashscope/qwen-omni-turbo
LL3M_VIDEO_API_BASE=
LL3M_VIDEO_API_KEY=
LL3M_VIDEO_API_VERSION=
LL3M_VIDEO_PROVIDER=

# Per-agent sampling. Keep coder/refiner low temperature for code stability.
LL3M_PLANNER_TEMPERATURE=0.2
# Leave MAX_TOKENS empty to avoid sending an output cap to the provider.
# Set only when a gateway/model requires an explicit limit.
LL3M_PLANNER_MAX_TOKENS=
LL3M_PLANNER_TIMEOUT_SECONDS=
LL3M_CODER_TEMPERATURE=0.1
LL3M_CODER_MAX_TOKENS=
LL3M_CODER_TIMEOUT_SECONDS=
LL3M_REFINER_TEMPERATURE=0.1
LL3M_REFINER_MAX_TOKENS=
LL3M_REFINER_TIMEOUT_SECONDS=
LL3M_VISION_TEMPERATURE=0.0
LL3M_VISION_MAX_TOKENS=
LL3M_VISION_TIMEOUT_SECONDS=
LL3M_VIDEO_TEMPERATURE=0.0
LL3M_VIDEO_MAX_TOKENS=
LL3M_VIDEO_TIMEOUT_SECONDS=

# Harness controls.
LL3M_LLM_TIMEOUT_SECONDS=90
LL3M_MAX_REFINEMENT_ROUNDS=2
LL3M_MAX_VISUAL_REFINEMENT_ROUNDS=6
LL3M_MAX_VIDEO_REFINEMENT_ROUNDS=6
LL3M_MAX_STAGNANT_REFINEMENT_ROUNDS=3
LL3M_PLANNER_MAX_RETRIES=1
LL3M_RAG_DOCS=docs/rag,docs/ir.md
LL3M_RUNS_DIR=runs
LL3M_BLENDER_HOST=localhost
LL3M_BLENDER_PORT=8888
LL3M_HEADLESS_RENDERING=false
LL3M_RENDER_WIDTH=1280
LL3M_RENDER_HEIGHT=720
LL3M_RENDER_GIF_EACH_ROUND=false
LL3M_TUI_INITIAL_ANIMATION=false
LL3M_TUI_SKIP_VISION=false
LL3M_TUI_SKIP_VIDEO=false
